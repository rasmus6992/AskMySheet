{
  "name": "maximus/talk-to-your-excel",
  "description": "Upload an Excel workbook and ask questions grounded only in its data.",
  "type": "project",
  "require": {
    "php": "^8.1",
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-zlib": "*",
    "phpoffice/phpspreadsheet": "^5.8"
  },
  "autoload": {
    "psr-4": {
      "TalkToExcel\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
